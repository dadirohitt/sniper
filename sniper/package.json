{
  "name": "sniper-backend",
  "version": "1.0.0",
  "description": "Sniper — Deterministic Meme Coin Evaluation Platform",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:stop": "npx pm2 stop sniper",
    "pm2:restart": "npx pm2 restart sniper",
    "pm2:logs": "npx pm2 logs sniper",
    "pm2:status": "npx pm2 status",
    "pm2:startup": "npx pm2 startup && npx pm2 save"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
